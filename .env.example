# Database Configuration
DB_ROOT_PASSWORD=rootpassword
DB_NAME=orderrun
DB_USERNAME=orderrun_user
DB_PASSWORD=orderrun_pass
DB_HOST=localhost
DB_PORT=3306

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Application Configuration
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400  # 24 hours in seconds

# OAuth - Kakao
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback

# OAuth - Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./keys/apple-private-key.p8
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# FCM (Firebase Cloud Messaging)
FCM_CREDENTIALS_PATH=./keys/firebase-service-account.json

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
