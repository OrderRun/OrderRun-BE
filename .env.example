# Database Configuration
DB_ROOT_PASSWORD=rootpassword
DB_NAME=orderrun
DB_USERNAME=orderrun_user
DB_PASSWORD=orderrun_pass
DB_HOST=localhost
DB_PORT=3306

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Application Configuration
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400  # 24 hours in seconds

# FCM (Firebase Cloud Messaging)
# 로컬 개발: 파일 경로 사용 (secrets/ 디렉토리는 gitignore됨)
FCM_CREDENTIALS_PATH=secrets/orderrun-firebase-key.json
# 배포 환경: JSON 문자열 사용 (GitHub Secret에 저장)
# FCM_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# AWS SNS (SMS)
AWS_SNS_REGION=ap-northeast-2
AWS_SNS_ACCESS_KEY_ID=
AWS_SNS_SECRET_ACCESS_KEY=
AWS_SNS_SMS_SENDER_ID=Kkobongdan
AWS_SNS_SMS_TYPE=Transactional

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
