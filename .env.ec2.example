# EC2 compose example.
# Copy this shape into an untracked env file on EC2, for example /home/ubuntu/orderrun/.env.ec2.

DOCKER_IMAGE=orderrun:latest
EC2_PUBLIC_IP=43.200.56.9
PROD_DOMAIN=api.kkobung-dan.store
STAGING_DOMAIN=staging-api.kkobung-dan.store
NGINX_TEMPLATE=./nginx/templates/ec2-staging-http.conf.template
LETSENCRYPT_EMAIL=admin@example.com

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

STAGING_LOG_LEVEL=INFO
STAGING_LOG_FILE_ENABLED=true
STAGING_LOG_RETENTION_DAYS=14
STAGING_APP_ENV=staging
STAGING_APP_DEBUG=false
STAGING_SECRET_KEY=replace-with-staging-secret
STAGING_JWT_SECRET=replace-with-staging-jwt-secret
STAGING_MYSQL_HOST=replace-with-rds-endpoint
STAGING_MYSQL_PORT=3306
STAGING_MYSQL_DATABASE=staging_orderun
STAGING_MYSQL_USER=replace-with-staging-db-user
STAGING_MYSQL_PASSWORD=replace-with-staging-db-password
STAGING_AWS_SNS_REGION=ap-northeast-1
STAGING_AWS_SNS_ACCESS_KEY_ID=
STAGING_AWS_SNS_SECRET_ACCESS_KEY=
STAGING_AWS_SNS_SMS_SENDER_ID=Kkobongdan
STAGING_AWS_SNS_SMS_TYPE=Transactional
STAGING_FCM_CREDENTIALS_PATH=
STAGING_FCM_CREDENTIALS_JSON=

PROD_LOG_LEVEL=INFO
PROD_LOG_FILE_ENABLED=true
PROD_LOG_RETENTION_DAYS=14
PROD_APP_ENV=production
PROD_APP_DEBUG=false
PROD_SECRET_KEY=replace-with-prod-secret
PROD_JWT_SECRET=replace-with-prod-jwt-secret
PROD_MYSQL_HOST=replace-with-rds-endpoint
PROD_MYSQL_PORT=3306
PROD_MYSQL_DATABASE=prod_orderun
PROD_MYSQL_USER=replace-with-prod-db-user
PROD_MYSQL_PASSWORD=replace-with-prod-db-password
PROD_AWS_SNS_REGION=ap-northeast-1
PROD_AWS_SNS_ACCESS_KEY_ID=
PROD_AWS_SNS_SECRET_ACCESS_KEY=
PROD_AWS_SNS_SMS_SENDER_ID=Kkobongdan
PROD_AWS_SNS_SMS_TYPE=Transactional
PROD_FCM_CREDENTIALS_PATH=
PROD_FCM_CREDENTIALS_JSON=
