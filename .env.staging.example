# Staging Docker image
DOCKER_IMAGE=orderrun:staging

# App runtime
APP_ENV=staging
APP_DEBUG=false
SECRET_KEY=change-this-staging-secret-key

# External MySQL for staging
MYSQL_HOST=staging-db.example.com
MYSQL_PORT=3306
MYSQL_DATABASE=orderrun
MYSQL_USER=orderrun_user
MYSQL_PASSWORD=change-this-staging-password

DB_HOST=staging-db.example.com
DB_PORT=3306
DB_NAME=orderrun
DB_USERNAME=orderrun_user
DB_PASSWORD=change-this-staging-password

# App secrets
JWT_SECRET=change-this-staging-jwt-secret

# OAuth placeholders
KAKAO_CLIENT_ID=mock-kakao-client-id
KAKAO_CLIENT_SECRET=mock-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback
APPLE_CLIENT_ID=mock-apple-client-id
APPLE_TEAM_ID=mock-apple-team-id
APPLE_KEY_ID=mock-apple-key-id
APPLE_PRIVATE_KEY_PATH=./keys/apple-private-key.p8
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# AWS SNS
AWS_SNS_REGION=ap-northeast-2
AWS_SNS_ACCESS_KEY_ID=
AWS_SNS_SECRET_ACCESS_KEY=
AWS_SNS_SMS_SENDER_ID=Kkobongdan

# Nginx / SSL
EC2_PUBLIC_IP=43.200.56.9
ENABLE_SSL=false
STAGING_DOMAIN=staging.example.com
LETSENCRYPT_EMAIL=admin@example.com
