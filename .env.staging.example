# Staging Docker image
DOCKER_IMAGE=orderrun:staging

# External MySQL for staging
MYSQL_HOST=staging-db.example.com
MYSQL_PORT=3306
MYSQL_DATABASE=orderrun
MYSQL_USER=orderrun_user
MYSQL_PASSWORD=change-this-staging-password

# App secrets
JWT_SECRET=change-this-staging-jwt-secret

# AWS SNS
AWS_SNS_REGION=ap-northeast-2
AWS_SNS_ACCESS_KEY_ID=
AWS_SNS_SECRET_ACCESS_KEY=
AWS_SNS_SMS_SENDER_ID=Kkobongdan

# Nginx / SSL
EC2_PUBLIC_IP=43.200.56.9
ENABLE_SSL=false
STAGING_DOMAIN=staging.example.com
LETSENCRYPT_EMAIL=admin@example.com
